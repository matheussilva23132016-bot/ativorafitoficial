generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model app_settings {
  id         Int       @id @default(autoincrement())
  chave      String    @unique(map: "unique_chave") @db.VarChar(100)
  valor      String    @db.VarChar(255)
  descricao  String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.DateTime(0)
  updated_at DateTime? @default(now()) @db.DateTime(0)
}

model ativora_announcements {
  id                  Int                               @id @default(autoincrement())
  community_id        String                            @db.VarChar(50)
  author_id           String                            @db.VarChar(50)
  title               String                            @db.VarChar(100)
  content             String                            @db.Text
  importance          ativora_announcements_importance? @default(normal)
  created_at          DateTime?                         @default(now()) @db.Timestamp(0)
  ativora_communities ativora_communities               @relation(fields: [community_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "ativora_announcements_ibfk_1")
  ativora_users       ativora_users                     @relation(fields: [author_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "ativora_announcements_ibfk_2")

  @@index([author_id], map: "author_id")
  @@index([community_id], map: "community_id")
}

model ativora_communities {
  id                    String                       @id @db.VarChar(50)
  name                  String                       @db.VarChar(255)
  description           String?                      @db.Text
  focus                 String?                      @default("Todos") @db.VarChar(100)
  privacy               ativora_communities_privacy? @default(public)
  theme                 String?                      @default("sky") @db.VarChar(50)
  cover_url             String?                      @db.LongText
  owner_id              String                       @db.VarChar(50)
  created_at            DateTime?                    @default(now()) @db.Timestamp(0)
  ativora_announcements ativora_announcements[]
  ativora_users         ativora_users                @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_owner")
  ativora_members       ativora_members[]

  @@index([owner_id], map: "fk_owner")
}

model ativora_evolution {
  id            Int           @id @default(autoincrement())
  user_id       String        @db.VarChar(50)
  peso          Decimal?      @db.Decimal(5, 2)
  bf            Decimal?      @db.Decimal(4, 2)
  cintura       Decimal?      @db.Decimal(5, 2)
  bra_o         Decimal?      @map("braço") @db.Decimal(5, 2)
  perna         Decimal?      @db.Decimal(5, 2)
  photo_url     String?       @db.LongText
  date          DateTime?     @default(now()) @db.Timestamp(0)
  ativora_users ativora_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "ativora_evolution_ibfk_1")

  @@index([user_id], map: "user_id")
}

model ativora_members {
  id                  Int                   @id @default(autoincrement())
  user_id             String                @db.VarChar(50)
  community_id        String                @db.VarChar(50)
  role                ativora_members_role? @default(ALUNO)
  joined_at           DateTime?             @default(now()) @db.Timestamp(0)
  ativora_users       ativora_users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "ativora_members_ibfk_1")
  ativora_communities ativora_communities   @relation(fields: [community_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "ativora_members_ibfk_2")

  @@unique([user_id, community_id], map: "unique_membership")
  @@index([community_id], map: "community_id")
}

model ativora_users {
  id                    String                  @id @db.VarChar(50)
  email                 String                  @unique(map: "email") @db.VarChar(255)
  password_hash         String                  @db.VarChar(255)
  full_name             String                  @db.VarChar(255)
  nickname              String?                 @unique(map: "nickname") @db.VarChar(50)
  genero                String?                 @db.VarChar(20)
  data_nascimento       DateTime?               @db.Date
  cidade_estado         String?                 @db.VarChar(100)
  interesses            String?                 @db.Text
  nivel                 String?                 @db.VarChar(50)
  freq                  String?                 @db.VarChar(50)
  peso                  String?                 @db.VarChar(20)
  altura                String?                 @db.VarChar(20)
  registro              String?                 @db.VarChar(50)
  exp                   String?                 @db.VarChar(50)
  modalidade            String?                 @db.VarChar(50)
  especialidade         String?                 @db.VarChar(100)
  seguidores            String?                 @db.VarChar(50)
  nicho                 String?                 @db.VarChar(100)
  rede                  String?                 @db.VarChar(50)
  role                  ativora_users_role?     @default(aluno)
  xp_score              Int?                    @default(0)
  created_at            DateTime?               @default(now()) @db.Timestamp(0)
  account_status        String?                 @default("active") @db.VarChar(20)
  avatar_url            String?                 @db.Text
  bio                   String?                 @db.Text
  current_streak        Int?                    @default(0)
  descricao             String?                 @db.Text
  email_verified        Boolean?                @default(false)
  external_link         String?                 @db.VarChar(255)
  failed_login_attempts Int?                    @default(0)
  locked_until          DateTime?               @db.DateTime(0)
  last_login_at         DateTime?               @db.DateTime(0)
  is_private            Boolean?                @default(false)
  is_verified           Boolean?                @default(false)
  last_post_date        DateTime?               @db.Date
  nivel_int             Int?                    @default(1)
  xp                    Int?                    @default(0)
  ativora_announcements ativora_announcements[]
  ativora_communities   ativora_communities[]
  ativora_evolution     ativora_evolution[]
  ativora_members       ativora_members[]
}

model cardapios {
  id                 String               @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  comunidade_id      String               @db.VarChar(36)
  criado_por         String               @db.VarChar(36)
  titulo             String               @db.VarChar(200)
  foco               String?              @db.VarChar(100)
  calorias_meta      Int?
  proteina_meta      Int?
  proteinas_dia      Int?
  carbo_meta         Int?
  gordura_meta       Int?
  status             cardapios_status     @default(draft)
  alvo               cardapios_alvo       @default(individual)
  alvo_user_id       String?              @db.VarChar(36)
  aluno_id           String?              @db.VarChar(36)
  aluno_nome         String?              @db.VarChar(200)
  solicitacao_id     String?              @db.VarChar(36)
  semana             String?              @db.VarChar(10)
  gerado_por_ia      Boolean              @default(false)
  ia_revisado        Boolean              @default(false)
  semana_ref         DateTime?            @db.Date
  obs                String?              @db.Text
  created_at         DateTime             @default(now()) @db.DateTime(0)
  updated_at         DateTime             @default(now()) @db.DateTime(0)
  comunidades        comunidades          @relation(fields: [comunidade_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "cardapios_ibfk_1")
  refeicoes_cardapio refeicoes_cardapio[]

  @@index([aluno_id, status], map: "idx_aluno_status")
  @@index([alvo_user_id], map: "idx_alvo_user")
  @@index([comunidade_id], map: "idx_comunidade")
}

model comentarios {
  id               Int       @id @default(autoincrement())
  post_id          Int
  usuario_nickname String    @db.VarChar(255)
  conteudo         String    @db.Text
  role_na_epoca    String?   @db.VarChar(50)
  created_at       DateTime? @default(now()) @db.Timestamp(0)

  @@index([post_id], map: "post_id")
}

model communities {
  id                 String               @id @db.VarChar(36)
  name               String               @db.VarChar(255)
  description        String?              @db.Text
  cover_url          String?              @db.Text
  owner_id           String               @db.VarChar(36)
  status             String?              @default("active") @db.VarChar(20)
  created_at         DateTime?            @default(now()) @db.Timestamp(0)
  updated_at         DateTime?            @default(now()) @db.Timestamp(0)
  community_members  community_members[]
  community_requests community_requests[]
  workouts           workouts[]
}

model community_members {
  id           String       @id @db.VarChar(36)
  community_id String?      @db.VarChar(36)
  user_id      String       @db.VarChar(36)
  tags         String?      @db.LongText
  status       String?      @default("pending") @db.VarChar(20)
  joined_at    DateTime?    @default(now()) @db.Timestamp(0)
  communities  communities? @relation(fields: [community_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_community")

  @@unique([community_id, user_id], map: "community_user_unique")
  @@index([user_id], map: "idx_members_user")
}

model community_requests {
  id           String       @id @db.VarChar(36)
  community_id String?      @db.VarChar(36)
  user_id      String       @db.VarChar(36)
  message      String?      @db.Text
  status       String?      @default("pending") @db.VarChar(20)
  created_at   DateTime?    @default(now()) @db.Timestamp(0)
  communities  communities? @relation(fields: [community_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_community_req")

  @@index([community_id], map: "fk_community_req")
  @@index([status], map: "idx_requests_status")
}

model comunidade_anuncios {
  id            String      @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  comunidade_id String      @db.VarChar(36)
  autor_id      String      @db.VarChar(36)
  titulo        String      @db.VarChar(200)
  conteudo      String      @db.Text
  fixado        Boolean     @default(false)
  created_at    DateTime    @default(now()) @db.DateTime(0)
  comunidades   comunidades @relation(fields: [comunidade_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "comunidade_anuncios_ibfk_1")

  @@index([comunidade_id], map: "idx_comunidade")
}

model comunidade_membro_tags {
  id                 String             @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  membro_id          String             @db.VarChar(36)
  tag_id             String             @db.VarChar(36)
  atribuido_por      String             @db.VarChar(36)
  created_at         DateTime           @default(now()) @db.DateTime(0)
  comunidade_membros comunidade_membros @relation(fields: [membro_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "comunidade_membro_tags_ibfk_1")
  comunidade_tags    comunidade_tags    @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "comunidade_membro_tags_ibfk_2")

  @@unique([membro_id, tag_id], map: "uq_membro_tag")
  @@index([membro_id], map: "idx_membro")
  @@index([tag_id], map: "idx_tag")
}

model comunidade_membros {
  id                     String                    @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  comunidade_id          String                    @db.VarChar(36)
  user_id                String                    @db.VarChar(36)
  status                 comunidade_membros_status @default(pendente)
  motivo_recusa          String?                   @db.Text
  joined_at              DateTime?                 @db.DateTime(0)
  created_at             DateTime                  @default(now()) @db.DateTime(0)
  comunidade_membro_tags comunidade_membro_tags[]
  comunidades            comunidades               @relation(fields: [comunidade_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "comunidade_membros_ibfk_1")

  @@unique([comunidade_id, user_id], map: "uq_membro")
  @@index([comunidade_id], map: "idx_comunidade")
  @@index([status], map: "idx_status")
  @@index([user_id], map: "idx_user")
}

model comunidade_tags {
  id                     String                   @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  comunidade_id          String                   @db.VarChar(36)
  nome                   String                   @db.VarChar(50)
  cor                    String                   @default("sky") @db.VarChar(20)
  nivel_poder            Int                      @default(1) @db.TinyInt
  created_at             DateTime                 @default(now()) @db.DateTime(0)
  comunidade_membro_tags comunidade_membro_tags[]
  comunidades            comunidades              @relation(fields: [comunidade_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "comunidade_tags_ibfk_1")

  @@index([comunidade_id], map: "idx_comunidade")
}

model comunidades {
  id                        String                      @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  nome                      String                      @db.VarChar(100)
  descricao                 String?                     @db.Text
  cover_url                 String?                     @db.VarChar(500)
  tema                      String                      @default("sky") @db.VarChar(20)
  foco                      String                      @default("Todas") @db.VarChar(50)
  privacidade               comunidades_privacidade     @default(public)
  status                    comunidades_status          @default(ativa)
  owner_id                  String                      @db.VarChar(36)
  total_membros             Int                         @default(0)
  created_at                DateTime                    @default(now()) @db.DateTime(0)
  updated_at                DateTime                    @default(now()) @db.DateTime(0)
  cardapios                 cardapios[]
  comunidade_anuncios       comunidade_anuncios[]
  comunidade_membros        comunidade_membros[]
  comunidade_tags           comunidade_tags[]
  desafios                  desafios[]
  medidas_corporais         medidas_corporais[]
  ranking_semanal           ranking_semanal[]
  solicitacoes_entrada      solicitacoes_entrada[]
  solicitacoes_nutricionais solicitacoes_nutricionais[]
  solicitacoes_treino       solicitacoes_treino[]
  treinos                   treinos[]
  usuario_selos             usuario_selos[]

  @@index([owner_id], map: "idx_owner")
  @@index([status], map: "idx_status")
}

model conquistas {
  id               Int       @id @default(autoincrement())
  usuario_nickname String    @db.VarChar(255)
  tipo_badge       String    @db.VarChar(50)
  conquistado_em   DateTime? @default(now()) @db.Timestamp(0)

  @@unique([usuario_nickname, tipo_badge], map: "unique_conquista")
}

model consent_types {
  id          Int        @id @default(autoincrement())
  nome        String     @unique(map: "unique_nome") @db.VarChar(50)
  descricao   String?    @db.VarChar(255)
  obrigatorio Boolean?   @default(true)
  versao      String?    @default("1.0") @db.VarChar(10)
  ativo       Boolean?   @default(true)
  created_at  DateTime?  @default(now()) @db.DateTime(0)
  consents    consents[]
}

model consents {
  id                 Int            @id @default(autoincrement())
  user_id            Int
  consent_type_id    Int?
  tipo_consentimento String         @db.VarChar(50)
  aceito             Boolean?       @default(false)
  data_aceite        DateTime?      @default(now()) @db.DateTime(0)
  ip_address         String?        @db.VarChar(45)
  user_agent         String?        @db.Text
  consent_types      consent_types? @relation(fields: [consent_type_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_consents_type")
  users              users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_consents_user")

  @@index([consent_type_id], map: "fk_consents_type")
  @@index([user_id], map: "fk_consents_user")
}

model curtidas {
  id               Int       @id @default(autoincrement())
  post_id          Int
  usuario_nickname String    @db.VarChar(255)
  created_at       DateTime? @default(now()) @db.Timestamp(0)

  @@unique([post_id, usuario_nickname], map: "unique_like")
}

model denuncias {
  id                   Int               @id @default(autoincrement())
  post_id              Int
  denunciante_nickname String            @db.VarChar(255)
  motivo               String            @db.VarChar(255)
  status               denuncias_status? @default(pendente)
  criado_em            DateTime?         @default(now()) @db.Timestamp(0)
  posts                posts             @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "denuncias_ibfk_1")

  @@index([post_id], map: "post_id")
}

model desafios {
  id                String               @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  comunidade_id     String               @db.VarChar(36)
  criado_por        String               @db.VarChar(36)
  titulo            String               @db.VarChar(200)
  descricao         String               @db.Text
  instrucoes        String?              @db.Text
  tipo_envio        desafios_tipo_envio  @default(check)
  xp_recompensa     Int                  @default(10)
  dia_semana        desafios_dia_semana?
  prazo             DateTime?            @db.DateTime(0)
  status            desafios_status      @default(ativo)
  created_at        DateTime             @default(now()) @db.DateTime(0)
  updated_at        DateTime             @default(now()) @db.DateTime(0)
  comunidades       comunidades          @relation(fields: [comunidade_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "desafios_ibfk_1")
  entregas_desafios entregas_desafios[]

  @@index([comunidade_id], map: "idx_comunidade")
  @@index([status], map: "idx_status")
}

model document_verifications {
  id             Int       @id @default(autoincrement())
  document_id    Int
  status         String?   @default("pendente") @db.VarChar(30)
  verificado_por Int?
  observacao     String?   @db.Text
  verificado_em  DateTime? @db.DateTime(0)
  created_at     DateTime? @default(now()) @db.DateTime(0)
  documents      documents @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_document_verifications_document")

  @@index([document_id], map: "fk_document_verifications_document")
}

model documents {
  id                     Int                      @id @default(autoincrement())
  user_id                Int
  tipo_documento         String                   @db.VarChar(50)
  nome_arquivo           String                   @db.VarChar(255)
  arquivo_url            String                   @db.VarChar(500)
  mime_type              String?                  @db.VarChar(100)
  tamanho_bytes          BigInt?
  status_verificacao     String?                  @default("pendente") @db.VarChar(30)
  observacao             String?                  @db.Text
  created_at             DateTime?                @default(now()) @db.DateTime(0)
  updated_at             DateTime?                @default(now()) @db.DateTime(0)
  document_verifications document_verifications[]
  users                  users                    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_documents_user")

  @@index([user_id], map: "fk_documents_user")
}

model enquetes_votos {
  id               Int    @id @default(autoincrement())
  post_id          Int
  usuario_nickname String @db.VarChar(255)
  opcao            Int
  posts            posts  @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "enquetes_votos_ibfk_1")

  @@unique([post_id, usuario_nickname], map: "unique_voto")
}

model entregas_desafios {
  id           String                   @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  desafio_id   String                   @db.VarChar(36)
  user_id      String                   @db.VarChar(36)
  conteudo     String?                  @db.Text
  arquivo_url  String?                  @db.VarChar(500)
  status       entregas_desafios_status @default(pendente)
  avaliado_por String?                  @db.VarChar(36)
  comentario   String?                  @db.Text
  xp_aplicado  Int                      @default(0)
  tentativa    Int                      @default(1) @db.TinyInt
  created_at   DateTime                 @default(now()) @db.DateTime(0)
  updated_at   DateTime                 @default(now()) @db.DateTime(0)
  desafios     desafios                 @relation(fields: [desafio_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "entregas_desafios_ibfk_1")

  @@index([desafio_id], map: "idx_desafio")
  @@index([status], map: "idx_status")
  @@index([user_id], map: "idx_user")
}

model exercicios_treino {
  id               String             @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  treino_id        String             @db.VarChar(36)
  ordem            Int                @default(1) @db.TinyInt
  nome             String             @db.VarChar(200)
  series           Int?               @db.TinyInt
  reps             String?            @db.VarChar(20)
  descanso         String?            @db.VarChar(20)
  cadencia         String?            @db.VarChar(20)
  rpe              Int?               @db.TinyInt
  video_url        String?            @db.VarChar(500)
  obs              String?            @db.Text
  concluido        Boolean            @default(false)
  carga_kg         Decimal?           @db.Decimal(6, 2)
  tempo_exec       String?            @db.VarChar(20)
  created_at       DateTime           @default(now()) @db.DateTime(0)
  treinos          treinos            @relation(fields: [treino_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "exercicios_treino_ibfk_1")
  treino_serie_log treino_serie_log[]

  @@index([treino_id], map: "idx_treino")
}

model influencer_profiles {
  id                Int       @id @default(autoincrement())
  user_id           Int       @unique(map: "user_id_unique")
  nome_criador      String?   @db.VarChar(120)
  nicho_principal   String?   @db.VarChar(120)
  plataformas       String?   @db.VarChar(255)
  seguidores_total  Int?      @default(0)
  tipo_conteudo     String?   @db.Text
  mini_bio          String?   @db.Text
  perfil_verificado Boolean?  @default(false)
  created_at        DateTime? @default(now()) @db.DateTime(0)
  updated_at        DateTime? @default(now()) @db.DateTime(0)
  users             users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_influencer_profiles_user")
}

model interests {
  id             Int              @id @default(autoincrement())
  nome           String           @db.VarChar(100)
  descricao      String?          @db.VarChar(255)
  ativo          Boolean?         @default(true)
  created_at     DateTime?        @default(now()) @db.DateTime(0)
  user_interests user_interests[]
}

model intern_profiles {
  id                Int       @id @default(autoincrement())
  user_id           Int       @unique(map: "user_id_unique")
  area_estagio      String?   @db.VarChar(120)
  faculdade         String?   @db.VarChar(150)
  periodo_atual     String?   @db.VarChar(50)
  supervisor_local  String?   @db.VarChar(150)
  mini_apresentacao String?   @db.Text
  status_validacao  String?   @default("pendente") @db.VarChar(30)
  created_at        DateTime? @default(now()) @db.DateTime(0)
  updated_at        DateTime? @default(now()) @db.DateTime(0)
  users             users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_intern_profiles_user")
}

model medidas_corporais {
  id                String                  @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  user_id           String                  @db.VarChar(36)
  comunidade_id     String                  @db.VarChar(36)
  data              DateTime                @default(dbgenerated("(curdate())")) @db.Date
  peso_kg           Decimal?                @db.Decimal(5, 2)
  altura_cm         Decimal?                @db.Decimal(5, 1)
  cintura_cm        Decimal?                @db.Decimal(5, 1)
  quadril_cm        Decimal?                @db.Decimal(5, 1)
  biceps_cm         Decimal?                @db.Decimal(5, 1)
  pescoco_cm        Decimal?                @db.Decimal(5, 1)
  imc               Decimal?                @db.Decimal(5, 2)
  rcq               Decimal?                @db.Decimal(5, 3)
  gordura_est       Decimal?                @db.Decimal(5, 2)
  classificacao_rcq String?                 @db.VarChar(20)
  metodo_calculo    String?                 @db.VarChar(10)
