  comunidade_id String      @db.VarChar(36)
  selo_id       String      @db.VarChar(36)
  semana_ref    DateTime?   @db.Date
  concedido_em  DateTime    @default(now()) @db.DateTime(0)
  selos         selos       @relation(fields: [selo_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "usuario_selos_ibfk_1")
  comunidades   comunidades @relation(fields: [comunidade_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "usuario_selos_ibfk_2")

  @@index([comunidade_id], map: "idx_comunidade")
  @@index([user_id], map: "idx_user")
  @@index([selo_id], map: "selo_id")
}

model usuarios {
  id                                                Int            @id @default(autoincrement())
  nickname                                          String         @unique(map: "nickname") @db.VarChar(50)
  bio                                               String?        @db.VarChar(255)
  descricao                                         String?        @db.Text
  foto_url                                          String?        @db.Text
  data_criacao                                      DateTime?      @default(now()) @db.Timestamp(0)
  role                                              usuarios_role? @default(aluno)
  is_verified                                       Boolean?       @default(false)
  external_link                                     String?        @db.VarChar(255)
  current_streak                                    Int?           @default(0)
  last_post_date                                    DateTime?      @db.Date
  longest_streak                                    Int?           @default(0)
  xp                                                Int?           @default(0)
  nivel                                             Int?           @default(1)
  is_private                                        Boolean?       @default(false)
  streak                                            Int?           @default(0)
  ultima_atividade                                  DateTime?      @db.Date
  seguidores_seguidores_seguidor_nicknameTousuarios seguidores[]   @relation("seguidores_seguidor_nicknameTousuarios")
  seguidores_seguidores_seguido_nicknameTousuarios  seguidores[]   @relation("seguidores_seguido_nicknameTousuarios")

  @@index([nickname], map: "nickname_2")
}

model weekly_progress {
  id                    String   @id @db.VarChar(36)
  user_id               String   @db.VarChar(36)
  community_id          String   @db.VarChar(36)
  week_start_date       DateTime @db.Date
  workouts_completed    Int?     @default(0)
  total_workouts        Int?     @default(5)
  completion_percentage Decimal? @default(0.00) @db.Decimal(5, 2)

  @@unique([user_id, week_start_date], map: "user_week_unique")
  @@index([user_id, community_id, week_start_date], map: "idx_weekly_progress")
}

model workout_exercises {
  id          String   @id @db.VarChar(36)
  workout_id  String   @db.VarChar(36)
  name        String   @db.VarChar(255)
  sets        Int
  reps        String   @db.VarChar(50)
  rest_time   String?  @db.VarChar(50)
  notes       String?  @db.Text
  media_url   String?  @db.Text
  order_index Int
  workouts    workouts @relation(fields: [workout_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_exercise_workout")

  @@index([workout_id], map: "fk_exercise_workout")
}

model workout_requests {
  id            String    @id @db.VarChar(36)
  community_id  String    @db.VarChar(36)
  user_id       String    @db.VarChar(36)
  focus         String    @db.VarChar(100)
  notes         String?   @db.Text
  ai_draft_json String?   @db.LongText
  status        String?   @default("pending") @db.VarChar(20)
  handled_by    String?   @db.VarChar(36)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
}

model workout_sessions {
  id                String              @id @db.VarChar(36)
  workout_id        String              @db.VarChar(36)
  user_id           String              @db.VarChar(36)
  status            String?             @default("in_progress") @db.VarChar(20)
  started_at        DateTime?           @default(now()) @db.Timestamp(0)
  completed_at      DateTime?           @db.Timestamp(0)
  feedback_rating   Int?
  feedback_notes    String?             @db.Text
  session_exercises session_exercises[]
  workouts          workouts            @relation(fields: [workout_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_session_workout")

  @@index([workout_id], map: "fk_session_workout")
  @@index([user_id, status], map: "idx_sessions_user")
}

model workouts {
  id                  String              @id @db.VarChar(36)
  community_id        String              @db.VarChar(36)
  assigned_to_user_id String?             @db.VarChar(36)
  target_group        String?             @db.VarChar(50)
  title               String              @db.VarChar(255)
  focus               String              @db.VarChar(100)
  description         String?             @db.Text
  day_of_week         String?             @db.VarChar(15)
  estimated_minutes   Int?
  created_by          String              @db.VarChar(36)
  status              String?             @default("published") @db.VarChar(20)
  created_at          DateTime?           @default(now()) @db.Timestamp(0)
  plan_id             String?             @db.VarChar(36)
  order_in_week       Int?                @default(0)
  sessao_numero       Int?                @default(1)
  request_id          String?             @db.VarChar(36)
  workout_exercises   workout_exercises[]
  workout_sessions    workout_sessions[]
  communities         communities         @relation(fields: [community_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_workout_community")

  @@index([assigned_to_user_id, community_id], map: "idx_workout_assignment")
  @@index([community_id, day_of_week], map: "idx_workouts_community")
}

